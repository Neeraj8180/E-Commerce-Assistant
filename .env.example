# =============================================================================
# E-Commerce Agentic AI System - Environment Configuration
#
# Copy this file to `.env`, then generate strong secrets:
#
#   make init-secrets        # writes JWT_SECRET + API_KEY into .env automatically
#
# Or, manually:
#   JWT_SECRET=$(openssl rand -hex 32)
#   API_KEY=$(openssl rand -hex 24)
#
# The Go server REFUSES TO START if JWT_SECRET (>=32 chars) or
# API_KEY (>=16 chars) is missing. This is intentional.
# =============================================================================

# -----------------------------------------------------------------------------
# LLM Provider (Ollama)
# -----------------------------------------------------------------------------
# Install Ollama: https://ollama.com/download
# Pull models:
#   ollama pull llama3.2
#   ollama pull nomic-embed-text
#
# When running services in Docker, the compose file maps `host.docker.internal`
# to the host gateway so containers can reach Ollama running on the host.
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.2
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_TIMEOUT_SECONDS=60

# Embedding dimension must match the model. nomic-embed-text => 768.
EMBED_DIMENSION=768

# -----------------------------------------------------------------------------
# PostgreSQL (with pgvector)
# -----------------------------------------------------------------------------
POSTGRES_USER=ecom
POSTGRES_PASSWORD=replace-with-strong-postgres-password
POSTGRES_DB=ecom_agent
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql://ecom:replace-with-strong-postgres-password@postgres:5432/ecom_agent

# -----------------------------------------------------------------------------
# Kafka
# -----------------------------------------------------------------------------
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TOPIC_CONVERSATIONS=agent.conversations
KAFKA_TOPIC_TOOL_CALLS=agent.tool_calls
KAFKA_TOPIC_ESCALATIONS=agent.escalations

# -----------------------------------------------------------------------------
# Go API Server - REQUIRED SECRETS (no defaults)
# -----------------------------------------------------------------------------
GO_SERVER_PORT=8080
# Run `make init-secrets` or `openssl rand -hex 32`
JWT_SECRET=
JWT_ISSUER=ecom-agent
JWT_TTL_MINUTES=60
# Run `make init-secrets` or `openssl rand -hex 24`
API_KEY=
RATE_LIMIT_RPS=10
RATE_LIMIT_BURST=20
PYTHON_AGENT_URL=http://python-agent:8000
PYTHON_AGENT_TIMEOUT_SECONDS=30
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# Python Agent Service
# -----------------------------------------------------------------------------
PYTHON_AGENT_PORT=8000
SHOPIFY_MOCK_URL=http://shopify-mock:8001
STRIPE_MOCK_URL=http://stripe-mock:8002
RAG_TOP_K=5
RAG_SCORE_THRESHOLD=0.5
REFUND_AUTO_APPROVE_LIMIT=50.0
RETURN_WINDOW_DAYS=30
MAX_FAILURES_BEFORE_ESCALATION=3

# -----------------------------------------------------------------------------
# Observability
# -----------------------------------------------------------------------------
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_SERVICE_NAMESPACE=ecom-agent
OTEL_TRACES_SAMPLER=parentbased_always_on
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_ADMIN_PASSWORD=replace-with-strong-grafana-password
