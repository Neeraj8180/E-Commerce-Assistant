{
  "title": "Agent Performance",
  "uid": "ecom-agent-perf",
  "schemaVersion": 38,
  "version": 1,
  "tags": ["ecom-agent"],
  "timezone": "browser",
  "time": {"from": "now-1h", "to": "now"},
  "refresh": "10s",
  "panels": [
    {
      "type": "stat",
      "title": "Total chat requests (5m)",
      "id": 1,
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
      "targets": [
        {
          "expr": "sum(increase(http_requests_total{service=\"go-server\",path=\"/chat\"}[5m]))",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Success rate (5m)",
      "id": 2,
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0},
      "fieldConfig": {"defaults": {"unit": "percentunit", "decimals": 2}},
      "targets": [
        {
          "expr": "sum(rate(agent_success_total[5m])) / clamp_min(sum(rate(agent_success_total[5m])) + sum(rate(agent_failure_total[5m])), 1e-9)",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Escalations (5m)",
      "id": 3,
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0},
      "targets": [{"expr": "sum(increase(escalation_total[5m]))", "refId": "A"}]
    },
    {
      "type": "stat",
      "title": "Hallucinations (5m)",
      "id": 4,
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 0},
      "targets": [{"expr": "sum(increase(hallucination_total[5m]))", "refId": "A"}]
    },
    {
      "type": "timeseries",
      "title": "Requests per second by intent",
      "id": 5,
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
      "targets": [
        {
          "expr": "sum by (intent) (rate(agent_success_total[1m]))",
          "legendFormat": "{{intent}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Agent failures by reason",
      "id": 6,
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
      "targets": [
        {
          "expr": "sum by (reason) (rate(agent_failure_total[5m]))",
          "legendFormat": "{{reason}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Tool calls per second",
      "id": 7,
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 12},
      "targets": [
        {
          "expr": "sum by (tool_name) (rate(tool_call_total[1m]))",
          "legendFormat": "{{tool_name}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "LLM token usage",
      "id": 8,
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 12},
      "targets": [
        {
          "expr": "sum by (kind) (rate(llm_token_usage_total[1m]))",
          "legendFormat": "{{kind}}",
          "refId": "A"
        }
      ]
    }
  ]
}
