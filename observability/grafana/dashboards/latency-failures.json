{
  "title": "Latency and Failures",
  "uid": "ecom-agent-latency",
  "schemaVersion": 38,
  "version": 1,
  "tags": ["ecom-agent"],
  "timezone": "browser",
  "time": {"from": "now-1h", "to": "now"},
  "refresh": "10s",
  "panels": [
    {
      "type": "timeseries",
      "title": "Go /chat latency (p50/p95/p99)",
      "id": 1,
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "fieldConfig": {"defaults": {"unit": "s"}},
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket{service=\"go-server\",path=\"/chat\"}[1m])) by (le))",
          "legendFormat": "p50", "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{service=\"go-server\",path=\"/chat\"}[1m])) by (le))",
          "legendFormat": "p95", "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{service=\"go-server\",path=\"/chat\"}[1m])) by (le))",
          "legendFormat": "p99", "refId": "C"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Agent latency by name (p95)",
      "id": 2,
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "fieldConfig": {"defaults": {"unit": "s"}},
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (agent_name, le) (rate(agent_latency_seconds_bucket[1m])))",
          "legendFormat": "{{agent_name}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Tool latency p95",
      "id": 3,
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "fieldConfig": {"defaults": {"unit": "s"}},
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (tool_name, le) (rate(tool_call_latency_seconds_bucket[1m])))",
          "legendFormat": "{{tool_name}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "HTTP error rate (4xx + 5xx)",
      "id": 4,
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "fieldConfig": {"defaults": {"unit": "percentunit"}},
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{status=~\"4..|5..\"}[5m])) / clamp_min(sum(rate(http_requests_total[5m])), 1e-9)",
          "legendFormat": "error rate",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Upstream failures by upstream/reason",
      "id": 5,
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16},
      "targets": [
        {
          "expr": "sum by (upstream, reason) (rate(upstream_failures_total[5m]))",
          "legendFormat": "{{upstream}} - {{reason}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "RAG retrieval scores (avg)",
      "id": 6,
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16},
      "targets": [
        {
          "expr": "histogram_quantile(0.5, sum by (doc_type, le) (rate(rag_retrieval_score_bucket[5m])))",
          "legendFormat": "p50 {{doc_type}}",
          "refId": "A"
        }
      ]
    }
  ]
}
